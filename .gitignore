# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
tfplan
*.tfplan

# Terraform variable files with secrets
*.tfvars.json
secrets.tfvars
*secrets*

# Terraform directories
.terraform/
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash log files
crash.log
crash.*.log

# Sensitive SSH keys
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
